---
import Site from "../layouts/Site.astro";

const skills: { k: string; items: string[] }[] = [
  { k: "Languages", items: ["Java", "TypeScript", "JavaScript", "Go", "Python", "C++", "SQL"] },
  { k: "Backend & architecture", items: ["NestJS", "Spring Boot", "FastAPI", "microservices", "event-driven systems", "REST", "GraphQL", "JWT / OAuth", "Socotra platform"] },
  { k: "Frontend", items: ["React", "Next.js", "Astro", "Redux", "Tailwind", "design systems"] },
  { k: "Data & DevOps", items: ["PostgreSQL", "MongoDB", "schema design", "Docker", "GitHub Actions", "Postman", "Jira"] },
];
---

<Site
  title="About — Abdulaleem Altarsha"
  description="Software engineer in Ankara. Production experience on a US insurance platform, plus systems built from scratch on the side. Trilingual, systems-minded."
  active="about"
>
  <section class="band">
    <div class="wrap">
      <div class="band-head">
        <span class="kicker">About</span>
        <h2>A bit about me</h2>
      </div>

      <div class="about-grid">
        <div class="bio reveal">
          <p>
            I'm a software engineer based in <strong>Ankara</strong>. For the past year or so I
            worked remotely with a <strong>Zürich</strong> team (Radity) on a US auto-insurance
            platform — real production software, real users, and the kind of on-call incidents
            that teach you more than any course.
          </p>
          <p>
            I'm comfortable across the full stack: an event-driven Java core, NestJS microservices,
            and React front-ends. The work I enjoy most is the debugging that spans services — the
            kind where the bug turns out to be <strong>three services away from the symptom</strong>.
          </p>
          <p>
            On my own time I tend to rebuild the infrastructure most people just import —
            <strong>a matching engine, a consensus protocol, a time-series database</strong>. I do it
            because understanding how something works underneath is the difference between using a
            tool and actually knowing a system. Each project ships with benchmarks, green CI, and a
            section I title "honest limitations."
          </p>
          <p>
            I speak <strong>English and Arabic natively</strong> and Turkish conversationally. I
            finished my Computer Engineering degree at <strong>Bilkent University</strong> in 2026.
          </p>
          <p style="font-size: 14.5px; color: var(--ink-3);">
            Certifications: Coursera — Programming Foundations with JS/HTML/CSS (with Honors);
            Python series (Databases, Web Data, Visualization); Intro to Cybersecurity Tools
            &amp; Cyber Attacks.
          </p>
        </div>

        <div class="reveal">
          {skills.map((g) => (
            <div class="skill-group">
              <div class="k">{g.k}</div>
              <div class="chips">
                {g.items.map((s) => <span class="chip">{s}</span>)}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="contact-card reveal" id="contact">
        <div>
          <h2>Open to what's next.</h2>
          <p>
            I'm looking for backend, full-stack, or platform roles — remote or hybrid.
            The fastest way to reach me is email; the fastest way to judge the work is the repos.
          </p>
        </div>
        <div class="btn-row">
          <a class="btn solid" href="mailto:abdulaleemtarshah@gmail.com">Email me</a>
          <a class="btn ghost" href="/Abdulaleem_Altarsha_CV.pdf">CV (PDF)</a>
        </div>
      </div>
    </div>
  </section>
</Site>
