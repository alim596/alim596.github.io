---
import Site from "../layouts/Site.astro";

const featured = [
  {
    href: "https://accentra-webpage.netlify.app/",
    img: "/img/accentra.png",
    alt: "Accentra landing page with beta call to action",
    name: "Accentra",
    tag: "NEXT.JS · FASTAPI",
    blurb: "AI language learning with CEFR-aligned exams, phoneme-level pronunciation feedback, and a project page with the beta walkthrough and video material.",
  },
  {
    href: "/projects#projectforge",
    img: "/img/projectforge.png",
    alt: "ProjectForge project-management board",
    name: "ProjectForge",
    tag: "REACT · FASTAPI",
    blurb: "Turn research and rough ideas into grounded, cost-aware software plans, then manage the work and generate the project with your own AI provider.",
  },
];
---

<Site
  title="Abdulaleem Altarsha — Software Engineer"
  description="Full-stack software engineer. Production experience on a US insurance platform, plus systems built from scratch — an exchange, a consensus engine, and an observability stack."
  active="home"
>
  <header class="hero">
    <canvas id="dots" aria-hidden="true"></canvas>
    <div class="wrap hero-content">
      <span class="kicker">Software Engineer · Full-Stack</span>
      <h1>Full-stack engineer<br />who likes the <span class="accent">hard parts</span>.</h1>
      <p class="lede">
        Most recently I built and shipped production features for a <strong>US auto-insurance
        platform</strong> at Radity — an event-driven Java core, NestJS microservices, and React
        front-ends. Alongside that, I build systems from the ground up —
        <strong>an exchange, a consensus engine, an observability platform</strong> — and back the
        claims with benchmarks and tests.
      </p>
      <div class="btn-row">
        <a class="btn solid" href="/projects">See the work →</a>
        <a class="btn ghost" href="https://github.com/alim596">GitHub</a>
        <a class="btn ghost" href="mailto:abdulaleemtarshah@gmail.com">Get in touch</a>
      </div>
      <div class="hero-meta">
        <span><b class="pulse">●</b> open to new roles</span>
        <span>most recently <b>SWE at Radity</b> (Zürich, remote)</span>
        <span><b>Bilkent CE</b> · graduated 2026</span>
        <span>Ankara, Türkiye</span>
      </div>
    </div>
  </header>

  <section class="band alt">
    <div class="wrap">
      <div class="band-head reveal">
        <span class="kicker">Selected work</span>
        <h2>A few things I've built</h2>
        <p>Current systems work, with green CI, real measurements, and honest limitations.</p>
      </div>
      <div class="feat-cards">
        {featured.map((f, i) => (
          <a class={`fcard reveal`} style={`transition-delay:${i * 90}ms`} href={f.href}>
            <div class={`thumb ${f.img ? "" : "placeholder"}`}>
              {f.img ? (
                <img src={f.img} alt={f.alt} loading={i === 0 ? "eager" : "lazy"} />
              ) : (
                <span>{f.name.toLowerCase()}</span>
              )}
            </div>
            <div class="fcard-body">
              <div class="name">{f.name}<span class="mono">{f.tag}</span></div>
              <p>{f.blurb}</p>
              <div class="go">Explore →</div>
            </div>
          </a>
        ))}
      </div>
      <div class="center-cta reveal">
        <a class="btn ghost" href="/projects">All projects, in depth →</a>
      </div>
    </div>
  </section>

  <script>
    // Hero: a quiet field of ink dots that leans away from the cursor.
    let cleanupDots: (() => void) | undefined;

    function initDots() {
      cleanupDots?.();

      const canvas = document.getElementById("dots") as HTMLCanvasElement | null;
      if (!canvas || matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      const ctx = canvas.getContext("2d")!;
      let w = 0, h = 0, raf = 0;
      const GAP = 34;
      const interactive = matchMedia("(hover: hover) and (pointer: fine)").matches;
      let dots: { x: number; y: number; ox: number; oy: number }[] = [];
      const mouse = { x: -9999, y: -9999 };

      const build = () => {
        const rect = canvas.getBoundingClientRect();
        w = canvas.width = rect.width * devicePixelRatio;
        h = canvas.height = rect.height * devicePixelRatio;
        dots = [];
        for (let y = GAP; y < rect.height; y += GAP) {
          for (let x = GAP; x < rect.width; x += GAP) {
            dots.push({ x, y, ox: x, oy: y });
          }
        }
      };

      const draw = () => {
        ctx.setTransform(devicePixelRatio, 0, 0, devicePixelRatio, 0, 0);
        ctx.clearRect(0, 0, w, h);
        for (const d of dots) {
          const dx = d.x - mouse.x;
          const dy = d.y - mouse.y;
          const dist = Math.hypot(dx, dy);
          const push = Math.max(0, 1 - dist / 130);
          const tx = d.ox + (dx / (dist || 1)) * push * 26;
          const ty = d.oy + (dy / (dist || 1)) * push * 26;
          d.x += (tx - d.x) * 0.12;
          d.y += (ty - d.y) * 0.12;
          ctx.beginPath();
          ctx.arc(d.x, d.y, push > 0.02 ? 2.1 : 1.4, 0, Math.PI * 2);
          ctx.fillStyle = push > 0.02 ? "rgba(25,72,209,0.55)" : "rgba(22,21,15,0.14)";
          ctx.fill();
        }
      };

      const step = () => {
        if (!canvas.isConnected) return;
        draw();
        raf = requestAnimationFrame(step);
      };

      const onMove = (e: MouseEvent) => {
        const r = canvas.getBoundingClientRect();
        mouse.x = e.clientX - r.left;
        mouse.y = e.clientY - r.top;
      };
      const onLeave = () => { mouse.x = -9999; mouse.y = -9999; };

      const hero = canvas.parentElement!;
      const onResize = () => {
        build();
        if (!interactive) draw();
      };

      build();
      addEventListener("resize", onResize);
      if (interactive) {
        hero.addEventListener("mousemove", onMove);
        hero.addEventListener("mouseleave", onLeave);
        step();
      } else {
        draw();
      }

      cleanupDots = () => {
        cancelAnimationFrame(raf);
        removeEventListener("resize", onResize);
        hero.removeEventListener("mousemove", onMove);
        hero.removeEventListener("mouseleave", onLeave);
        cleanupDots = undefined;
      };
    }
    initDots();
    document.addEventListener("astro:page-load", initDots);
    document.addEventListener("astro:before-swap", () => cleanupDots?.());
  </script>
</Site>
